<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.carwash.mapper.StoreHolidayMapper">

    <select id="findByStore" resultType="com.carwash.domain.StoreHoliday">
        SELECT id, store_id, `date`, approved FROM store_holiday
        WHERE store_id = #{storeId} ORDER BY `date`
    </select>

    <!-- id는 BIGINT AUTO_INCREMENT 내부 surrogate(미세팅) -->
    <insert id="insert">
        INSERT INTO store_holiday (store_id, `date`, approved)
        VALUES (#{storeId}, #{date}, #{approved})
    </insert>
</mapper>
