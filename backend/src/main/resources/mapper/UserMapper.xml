<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.carwash.mapper.UserMapper">

    <select id="findAll" resultType="com.carwash.domain.User">
        SELECT id, email, name, role FROM users ORDER BY id
    </select>

    <select id="findById" resultType="com.carwash.domain.User">
        SELECT id, email, name, role FROM users WHERE id = #{id}
    </select>

    <select id="findByEmail" resultType="com.carwash.domain.User">
        SELECT id, email, name, role FROM users WHERE email = #{email}
    </select>
</mapper>
