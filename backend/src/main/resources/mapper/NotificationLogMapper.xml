<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.carwash.mapper.NotificationLogMapper">

    <!-- 발송 이력 기록 — id는 AUTO_INCREMENT(useGeneratedKeys), created_at은 DB DEFAULT -->
    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO notification_log (recipient, type, subject, status)
        VALUES (#{recipient}, #{type}, #{subject}, #{status})
    </insert>
</mapper>
