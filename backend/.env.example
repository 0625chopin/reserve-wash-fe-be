# .env 템플릿 — 이 파일을 복사해 `.env`로 만든 뒤 실제 값으로 채운다.
#   cp .env.example .env   (PowerShell: Copy-Item .env.example .env)
# .env는 자격증명을 포함하므로 커밋하지 않는다(.gitignore 등록). 이 .example만 커밋한다.
# Spring이 application.yml의 spring.config.import(optional:file:.env[.properties])로 읽는다.

# --- 알림 SMTP ---
# 미설정 시 기본값으로 로컬 메일 캐처(MailHog/Mailpit, localhost:1025)에 발송된다.
# Gmail 사용 예시 ↓ (host/port/auth/starttls는 그대로, username/password만 교체)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS=true
# Gmail 주소 + 16자리 앱 비밀번호(2단계 인증 후 https://myaccount.google.com/apppasswords 에서 발급)
MAIL_USERNAME=
MAIL_PASSWORD=
